# ─── Supabase (required) ──────────────────────────────────────────────
# Get these from your Supabase dashboard → Project Settings → API

# Public URL + public anon key — shipped to the browser. Safe to expose.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key — server-side only. Bypasses RLS. NEVER commit.
# Used by /api/admin/* routes and server-side queries.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Site (required) ──────────────────────────────────────────────────
# Canonical base URL used in <meta> tags, sitemap.xml, and openGraph.
# In production set this to your live domain.
NEXT_PUBLIC_SITE_URL=https://nanobijoux.dz

# ─── Admin bootstrap (required) ───────────────────────────────────────
# First-boot fallback credentials for /admin/login BEFORE any admin row
# exists in `admin_users`. Once you create a real admin via SQL or UI,
# these become irrelevant. Change the defaults.
ADMIN_USER=admin
ADMIN_PASS=change-me-now

# JWT signing secret for admin_session cookies. >= 32 random chars.
# Changing this invalidates every active admin session.
ADMIN_SECRET=generate-a-long-random-string-at-least-32-chars
